# Used by axiosInstance.js as the base URL for all API calls
# Local dev:
VITE_API_URL=https://authbuild-pro1.onrender.com/api

# Production (uncomment and set your Railway URL):
# VITE_API_URL=https://your-app.railway.app/api

# Google OAuth client ID (same value as backend)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com